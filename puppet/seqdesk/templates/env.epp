# Database
DATABASE_URL="<%= $database_url %>"

# NextAuth.js
NEXTAUTH_URL="<%= $nextauth_url %>"
NEXTAUTH_SECRET="<%= $nextauth_secret %>"

# ENA Credentials (for submission module)
ENA_USERNAME=""
ENA_PASSWORD=""
ENA_TEST_MODE="true"

# Optional: File storage base path
DATA_BASE_PATH=""

# Port (must match NEXTAUTH_URL)
PORT="<%= $port %>"
