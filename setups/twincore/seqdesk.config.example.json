{
  "$schema": "../../docs/seqdesk-config-schema.json",
  "_comment": "Example seqdesk.config.json for the twincore environment. Copy to project root as seqdesk.config.json (then set \"$schema\" to \"./docs/seqdesk-config-schema.json\") or paste into Admin > Infrastructure import.",
  "site": {
    "name": "Twincore",
    "dataBasePath": "/net/broker/devphil/seqdesk_data",
    "contactEmail": "sequencing@example.com"
  },
  "pipelines": {
    "enabled": true,
    "execution": {
      "mode": "slurm",
      "runDirectory": "/net/broker/devphil/pipeline",
      "conda": {
        "enabled": true,
        "path": "/net/broker/devphil/miniconda3",
        "environment": "seqdesk-pipelines"
      },
      "slurm": {
        "enabled": true,
        "queue": "cpu",
        "cores": 4,
        "memory": "64GB",
        "timeLimit": 12,
        "options": "--qos=broker"
      }
    },
    "mag": {
      "enabled": true,
      "version": "3.4.0",
      "stubMode": false,
      "skipProkka": true,
      "skipConcoct": true
    }
  },
  "ena": {
    "testMode": true,
    "centerName": "My Center"
  },
  "sequencingFiles": {
    "extensions": [".fastq.gz", ".fq.gz", ".fastq", ".fq"],
    "scanDepth": 2,
    "allowSingleEnd": false,
    "ignorePatterns": ["**/tmp/**", "**/undetermined/**"],
    "simulationMode": "auto",
    "simulationTemplateDir": "_simulation_templates/mag"
  },
  "auth": {
    "allowRegistration": true,
    "requireEmailVerification": false,
    "sessionTimeout": 24
  }
}
