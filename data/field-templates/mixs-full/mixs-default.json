{
  "name": "ENA default sample checklist",
  "description": "Minimum information required for the sample",
  "version": "1.0.0",
  "source": "https://www.ebi.ac.uk/ena/browser/view/ERC000011",
  "category": "mixs",
  "accession": "ERC000011",
  "fields": [
    {
      "type": "text",
      "label": "cell_type",
      "name": "cell_type",
      "required": false,
      "visible": true,
      "helpText": "cell type from which the sample was obtained",
      "group": "Part and developmental stage of organism"
    },
    {
      "type": "text",
      "label": "dev_stage",
      "name": "dev_stage",
      "required": false,
      "visible": true,
      "helpText": "if the sample was obtained from an organism in a specific developmental stage, it is specified with this qualifier",
      "group": "Part and developmental stage of organism"
    },
    {
      "type": "text",
      "label": "germline",
      "name": "germline",
      "required": false,
      "visible": true,
      "helpText": "the sample described presented in the entry has not undergone somatic genomic rearrangement as part of an adaptive immune response; it is the unrearranged molecule that was inherited from the parental germline",
      "group": "Part and developmental stage of organism"
    },
    {
      "type": "text",
      "label": "tissue_lib",
      "name": "tissue_lib",
      "required": false,
      "visible": true,
      "helpText": "tissue library from which sample was obtained",
      "group": "Part and developmental stage of organism"
    },
    {
      "type": "text",
      "label": "tissue_type",
      "name": "tissue_type",
      "required": false,
      "visible": true,
      "helpText": "tissue type from which the sample was obtained",
      "group": "Part and developmental stage of organism"
    },
    {
      "type": "text",
      "label": "isolation_source",
      "name": "isolation_source",
      "required": false,
      "visible": true,
      "helpText": "describes the physical, environmental and/or local geographical source of the biological sample from which the sample was derived",
      "group": "Collection event information"
    },
    {
      "type": "text",
      "label": "lat_lon",
      "name": "lat_lon",
      "required": false,
      "visible": true,
      "helpText": "geographical coordinates of the location where the specimen was collected",
      "group": "Collection event information"
    },
    {
      "type": "text",
      "label": "collected_by",
      "name": "collected_by",
      "required": false,
      "visible": true,
      "helpText": "name of persons or institute who collected the specimen",
      "group": "Collection event information"
    },
    {
      "type": "text",
      "label": "collection date",
      "name": "collection_date",
      "required": true,
      "visible": true,
      "helpText": "The date the sample was collected with the intention of sequencing, either as an instance (single point in time) or interval. In case no exact time is available, the date/time can be right truncated i.e. all of these are valid ISO8601 compliant times: 2008-01-23T19:23:10+00:00; 2008-01-23T19:23:10; 2008-01-23; 2008-01; 2008.",
      "group": "Collection event information",
      "simpleValidation": {
        "pattern": "(^[12][0-9]{3}(-(0[1-9]|1[0-2])(-(0[1-9]|[12][0-9]|3[01])(T[0-9]{2}:[0-9]{2}(:[0-9]{2})?Z?([+-][0-9]{1,2})?)?)?)?(/[0-9]{4}(-[0-9]{2}(-[0-9]{2}(T[0-9]{2}:[0-9]{2}(:[0-9]{2})?Z?([+-][0-9]{1,2})?)?)?)?)?$)|(^not collected$)|(^not provided$)|(^restricted access$)|(^missing: control sample$)|(^missing: sample group$)|(^missing: synthetic construct$)|(^missing: lab stock$)|(^missing: third party data$)|(^missing: data agreement established pre-2023$)|(^missing: endangered species$)|(^missing: human-identifiable$)",
        "patternMessage": "Must match pattern: (^[12][0-9]{3}(-(0[1-9]|1[0-2])(-(0[1-9]|[12][0-9]|3[01])(T[0-9]{2}:[0-9]{2}(:[0-9]{2})?Z?([+-][0-9]{1,2})?)?)?)?(/[0-9]{4}(-[0-9]{2}(-[0-9]{2}(T[0-9]{2}:[0-9]{2}(:[0-9]{2})?Z?([+-][0-9]{1,2})?)?)?)?)?$)|(^not collected$)|(^not provided$)|(^restricted access$)|(^missing: control sample$)|(^missing: sample group$)|(^missing: synthetic construct$)|(^missing: lab stock$)|(^missing: third party data$)|(^missing: data agreement established pre-2023$)|(^missing: endangered species$)|(^missing: human-identifiable$)"
      }
    },
    {
      "type": "select",
      "label": "geographic location (country and/or sea)",
      "name": "geographic_location_country_and_or_sea",
      "required": true,
      "visible": true,
      "helpText": "The location the sample was collected from with the intention of sequencing, as defined by the country or sea. Country or sea names should be chosen from the INSDC country list (http://insdc.org/country.html).",
      "group": "Collection event information",
