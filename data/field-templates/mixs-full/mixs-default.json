      "type": "text",
      "label": "identified_by",
      "name": "identified_by",
      "required": false,
      "visible": true,
      "helpText": "name of the expert who identified the specimen taxonomically",
      "group": "Collection event information"
    },
    {
      "type": "select",
      "label": "environmental_sample",
      "name": "environmental_sample",
      "required": false,
      "visible": true,
      "helpText": "identifies sequences derived by direct molecular isolation from a bulk environmental DNA sample (by PCR with or without subsequent cloning of the product, DGGE, or other anonymous methods) with no reliable identification of the source organism",
      "group": "sample collection",
      "options": [
        {
          "value": "No",
          "label": "No"
        },
        {
          "value": "Yes",
          "label": "Yes"
        }
      ]
    },
    {
      "type": "text",
      "label": "mating_type",
      "name": "mating_type",
      "required": false,
      "visible": true,
      "helpText": "mating type of the organism from which the sequence was obtained; mating type is used for prokaryotes, and for eukaryotes that undergo meiosis without sexually dimorphic gametes",
      "group": "Organism characteristics"
    },
    {
      "type": "text",
      "label": "sex",
      "name": "sex",
      "required": false,
      "visible": true,
      "helpText": "sex of the organism from which the sample was obtained",
      "group": "Organism characteristics"
    },
    {
      "type": "text",
      "label": "lab_host",
      "name": "lab_host",
      "required": false,
      "visible": true,
      "helpText": "scientific name of the laboratory host used to propagate the source organism from which the sample was obtained",
      "group": "host description"
    },
    {
      "type": "text",
      "label": "host scientific name",
      "name": "host_scientific_name",
      "required": false,
      "visible": true,
      "helpText": "Scientific name of the natural (as opposed to laboratory) host to the organism from which sample was obtained.",
      "group": "host description"
    },
    {
      "type": "text",
      "label": "bio_material",
      "name": "bio_material",
      "required": false,
      "visible": true,
      "helpText": "Unique identifier that references the biological material from which the sample was obtained and that ideally exists in a curated collection (e.g. stock centres, seed banks, DNA banks). The ID should have the following structure: name of the institution (institution code) followed by the collection code (if available) and the voucher id (institution_code:collection_code:voucher_id). Please note institution codes and collection codes are taken from a controlled vocabulary maintained by the INSDC: https://ftp.ncbi.nih.gov/pub/taxonomy/biocollections/",
      "group": "Pointer to physical material"
    },
    {
      "type": "text",
      "label": "culture_collection",
      "name": "culture_collection",
      "required": false,
      "visible": true,
      "helpText": "Unique identifier that references the culture (e.g. live microbial and viral cultures and cell lines) from which the sample has been obtained and that have been deposited in curated culture collections. The ID needs to provide an institution code and the culture id, with optional collection code, in the following structure: (-institution_code:(collection_code):voucher_id. Please note institution codes (and optional collection codes) are taken from a controlled vocabulary maintained by the INSDC: https://ftp.ncbi.nih.gov/pub/taxonomy/biocollections/",
      "group": "Pointer to physical material"
    },
    {
      "type": "text",
      "label": "specimen_voucher",
      "name": "specimen_voucher",
      "required": false,
      "visible": true,
      "helpText": "Unique identifier that references the physical specimen that remains after the sequence has been obtained and that ideally exists in a curated collection. The ID should have the following structure: name of the institution (institution code) followed by the collection code (if available) and the voucher id (institution_code:collection_code:voucher_id). Please note institution codes and collection codes are taken from a controlled vocabulary maintained by the INSDC: https://ftp.ncbi.nih.gov/pub/taxonomy/biocollections/",
      "group": "Pointer to physical material"
    },
    {
      "type": "text",
      "label": "cultivar",
      "name": "cultivar",
      "required": false,
      "visible": true,
      "helpText": "cultivar (cultivated variety) of plant from which sample was obtained",
      "group": "Infraspecies information"
    },
    {
      "type": "text",
      "label": "ecotype",
      "name": "ecotype",
      "required": false,
      "visible": true,
      "helpText": "a population within a given species displaying genetically based, phenotypic traits that reflect adaptation to a local habitat.",
      "group": "Infraspecies information"
    },
    {
      "type": "text",
      "label": "isolate",
      "name": "isolate",
      "required": false,
      "visible": true,
      "helpText": "individual isolate from which the sample was obtained",
      "group": "Infraspecies information"
    },
    {
      "type": "text",
      "label": "sub_species",
      "name": "sub_species",
      "required": false,
      "visible": true,
      "helpText": "name of sub-species of organism from which sample was obtained",
      "group": "Infraspecies information"
    },
    {
      "type": "text",
      "label": "variety",
      "name": "variety",
      "required": false,
      "visible": true,
      "helpText": "variety (= varietas, a formal Linnaean rank) of organism from which sample was derived.",
      "group": "Infraspecies information"
    },
    {
      "type": "text",
      "label": "sub_strain",
      "name": "sub_strain",
      "required": false,
      "visible": true,
      "helpText": "name or identifier of a genetically or otherwise modified strain from which sample was obtained, derived from a parental strain (which should be annotated in the strain field; sub_strain from which sample was obtained",
      "group": "Infraspecies information"
    },
    {
      "type": "text",
      "label": "cell_line",
      "name": "cell_line",
      "required": false,
      "visible": true,
      "helpText": "cell line from which the sample was obtained",
      "group": "Infraspecies information"
    },
    {
      "type": "text",
      "label": "serotype",
      "name": "serotype",
      "required": false,
      "visible": true,
      "helpText": "serological variety of a species characterized by its antigenic properties",
      "group": "Infraspecies information"
    },
    {
      "type": "text",
      "label": "serovar",
      "name": "serovar",
      "required": false,
      "visible": true,
      "helpText": "serological variety of a species (usually a prokaryote) characterized by its antigenic properties",
      "group": "Infraspecies information"
    },
    {
      "type": "text",
      "label": "strain",
      "name": "strain",
      "required": false,
      "visible": true,
      "helpText": "Name of the strain from which the sample was obtained.",
      "group": "Infraspecies information"
    }
