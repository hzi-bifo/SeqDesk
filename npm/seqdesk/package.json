{
  "name": "seqdesk",
  "version": "1.1.122",
  "description": "CLI launcher for installing and updating SeqDesk",
  "scripts": {
    "sync-version": "node ./scripts/sync-version.js",
    "prepublishOnly": "node ./scripts/sync-version.js",
    "release:check": "npm run sync-version && npm pack --dry-run",
    "release:publish": "npm run release:check && npm publish --access public"
  },
  "bin": {
    "seqdesk": "bin/seqdesk.js"
  },
  "files": [
    "bin/seqdesk.js",
    "README.md",
    "MANUAL_INSTALL.md",
    "scripts/sync-version.js"
  ],
  "engines": {
    "node": ">=22.13.0 <23 || >=24 <25"
  },
  "keywords": [
    "seqdesk",
    "installer"
  ],
  "license": "MIT"
}
