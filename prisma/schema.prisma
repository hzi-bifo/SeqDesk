generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  firstName      String
  lastName       String
  phone          String?
  role           String          @default("RESEARCHER")
  isDemo         Boolean         @default(false)
  researcherRole String?
  institution    String?
  facilityName   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  departmentId   String?
  demoWorkspace  DemoWorkspace?  @relation("DemoWorkspaceResearcher")
  adminDemoWorkspace DemoWorkspace? @relation("DemoWorkspaceAdmin")
  usedInvite     AdminInvite?    @relation("InviteUser")
  createdInvites AdminInvite[]   @relation("InviteCreator")
  orders         Order[]
  statusNotes    StatusNote[]
  studies          Study[]         @relation("StudyOwner")
  studyNotesEdited Study[]         @relation("StudyNotesEditor")
  tickets          Ticket[]
  ticketMessages TicketMessage[]
  pipelineRuns   PipelineRun[]
  department     Department?     @relation(fields: [departmentId], references: [id])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model Order {
  id               String       @id @default(cuid())
  orderNumber      String       @unique
  name             String?
  generatedByE2E   Boolean      @default(false)
  status           String       @default("DRAFT")
  statusUpdatedAt  DateTime     @default(now())
  numberOfSamples  Int?
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  billingAddress   String?
  platform         String?
  instrumentModel  String?
  librarySelection String?
  libraryStrategy  String?
  librarySource    String?
  customFields     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  samples          Sample[]
  sampleset        Sampleset?
  statusNotes      StatusNote[]
  tickets          Ticket[]     @relation("TicketOrder")
}

model Study {
  id                 String        @id @default(cuid())
  title              String
  alias              String?
  description        String?
  generatedByE2E     Boolean       @default(false)
  checklistType      String?
  studyMetadata      String?
  readyForSubmission Boolean       @default(false)
  readyAt            DateTime?
  studyAccessionId   String?
  submitted          Boolean       @default(false)
  submittedAt        DateTime?
  testRegisteredAt   DateTime?
  notes              String?
  notesEditedAt      DateTime?
  notesEditedById    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  userId             String
  samples            Sample[]
  pipelineRuns       PipelineRun[]
  user               User          @relation("StudyOwner", fields: [userId], references: [id])
  notesEditedBy      User?         @relation("StudyNotesEditor", fields: [notesEditedById], references: [id])
  tickets            Ticket[]      @relation("TicketStudy")
}

model Sampleset {
  id             String  @id @default(cuid())
  checklists     String
  selectedFields String?
  fieldOverrides String?
  sampleType     Int     @default(1)
  orderId        String  @unique
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Sample {
  id                    String     @id @default(cuid())
  sampleId              String
  sampleAlias           String?
  sampleTitle           String?
  sampleDescription     String?
  scientificName        String?
  taxId                 String?
  sampleAccessionNumber String?
  biosampleNumber       String?
  checklistData         String?
  checklistUnits        String?
  customFields          String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  orderId               String
  studyId               String?
  assemblies            Assembly[] @relation("SampleAssemblies")
  preferredAssemblyId   String?    @unique
  preferredAssembly     Assembly?  @relation("PreferredAssembly", fields: [preferredAssemblyId], references: [id], onDelete: SetNull)
  bins                  Bin[]
  reads                 Read[]
  study                 Study?     @relation(fields: [studyId], references: [id])
  order                 Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Read {
  id                        String         @id @default(cuid())
  file1                     String?
  file2                     String?
  checksum1                 String?
  checksum2                 String?
  experimentAccessionNumber String?
  runAccessionNumber        String?
  readCount1                Int?
  readCount2                Int?
  avgQuality1               Float?
  avgQuality2               Float?
  fastqcReport1             String?
  fastqcReport2             String?
  sampleId                  String
  sequencingRunId           String?
  sequencingRun             SequencingRun? @relation(fields: [sequencingRunId], references: [id])
  sample                    Sample         @relation(fields: [sampleId], references: [id], onDelete: Cascade)
}

model SequencingRun {
  id             String    @id @default(cuid())
  runId          String    @unique
  runName        String?
  platform       String?
  instrument     String?
  runDate        DateTime?
  folderPath     String?
  q30Score       Float?
  clusterDensity Float?
  passFilterPct  Float?
  totalReads     Int?
  totalBases     BigInt?
  multiQcReport  String?
  demuxStats     String?
  runParameters  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  reads          Read[]
}

model Assembly {
  id                     String       @id @default(cuid())
  assemblyName           String?
  assemblyFile           String?
  assemblyAccession      String?
  sampleId               String
  sample                 Sample       @relation("SampleAssemblies", fields: [sampleId], references: [id], onDelete: Cascade)
  preferredBySample      Sample?      @relation("PreferredAssembly")
  // Track which pipeline created this assembly
  createdByPipelineRunId String?
  createdByPipelineRun   PipelineRun? @relation(fields: [createdByPipelineRunId], references: [id])
}

model Bin {
  id                     String       @id @default(cuid())
  binName                String?
  binAccession           String?
  binFile                String?
  completeness           Float?
  contamination          Float?
  sampleId               String
  sample                 Sample       @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  // Track which pipeline created this bin
  createdByPipelineRunId String?
  createdByPipelineRun   PipelineRun? @relation(fields: [createdByPipelineRunId], references: [id])
}

// ============================================================================
// PIPELINE SYSTEM
// ============================================================================

// Pipeline configuration (enabled/disabled + settings per pipeline type)
model PipelineConfig {
  id         String   @id @default(cuid())
  pipelineId String   @unique // 'mag', 'submg', 'fastqc'
  enabled    Boolean  @default(false)
  config     String? // JSON: pipeline-specific settings
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Individual pipeline execution record
model PipelineRun {
  id         String @id @default(cuid())
  runNumber  String @unique // MAG-20240126-001
  pipelineId String // 'mag', 'submg', 'fastqc'
  status     String @default("pending") // pending, queued, running, completed, failed, cancelled

  // Configuration snapshot at run time
  config         String? // JSON
  inputSampleIds String? // JSON array of sample IDs selected for this run

  // Input - which study this run is for
  studyId String?
  study   Study?  @relation(fields: [studyId], references: [id])

  // Execution details
  runFolder   String? // Path to run directory
  queueJobId  String? // SLURM job ID or task queue ID
  progress    Int? // 0-100
  currentStep String? // "Running MEGAHIT..."

  // Timing
  queuedAt     DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  lastEventAt  DateTime?
  lastWeblogAt DateTime?
  lastTraceAt  DateTime?
  statusSource String? // weblog, trace, process, launcher

  // Logs (stored as paths for large outputs)
  outputPath String? // Path to stdout file
  errorPath  String? // Path to stderr file
  outputTail String? // Last ~100 lines of output for quick preview
  errorTail  String? // Last ~100 lines of error

  // Results summary
  results String? // JSON summary of outputs

  // Queue tracking (SLURM/local)
  queueStatus    String? // RUNNING, PENDING, etc.
  queueReason    String?
  queueUpdatedAt DateTime?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Who started this run
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Track outputs created by this run
  assembliesCreated Assembly[]
  binsCreated       Bin[]
  steps             PipelineRunStep[]
  events            PipelineRunEvent[]
  artifacts         PipelineArtifact[]
}

// Individual step within a pipeline run (for DAG visualization)
model PipelineRunStep {
  id            String      @id @default(cuid())
  pipelineRunId String
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  stepId        String // e.g., "FASTQC", "MEGAHIT", "METABAT2" - from Nextflow process names
  stepName      String? // Human-readable name
  status        String      @default("pending") // pending, running, completed, failed, skipped
  startedAt     DateTime?
  completedAt   DateTime?
  outputPath    String?
  errorPath     String?
  outputTail    String? // Last lines of output
  errorTail     String? // Last lines of error

  @@unique([pipelineRunId, stepId])
}

// Event feed for pipeline runs (weblog/trace/queue updates)
model PipelineRunEvent {
  id            String      @id @default(cuid())
  pipelineRunId String
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  eventType     String
  processName   String?
  stepId        String?
  status        String?
  message       String?
  payload       String? // JSON (trimmed)
  source        String? // weblog, trace, queue, process
  occurredAt    DateTime    @default(now())

  @@index([pipelineRunId, occurredAt])
}

// Artifacts produced by pipeline runs (files, reports, etc.)
model PipelineArtifact {
  id               String       @id @default(cuid())
  type             String // "reads", "assembly", "bins", "qc_report", "alignment"
  name             String? // Display name
  path             String // Absolute or relative path to artifact
  checksum         String? // MD5 or SHA256
  size             BigInt? // File size in bytes
  studyId          String?
  sampleId         String?
  pipelineRunId    String?
  pipelineRun      PipelineRun? @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  producedByStepId String? // Which step produced this
  metadata         String? // JSON for tool-specific info
  createdAt        DateTime     @default(now())
}

model StatusNote {
  id        String   @id @default(cuid())
  noteType  String   @default("INTERNAL")
  content   String
  createdAt DateTime @default(now())
  orderId   String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model SiteSettings {
  id                         String   @id @default("singleton")
  siteName                   String   @default("SeqDesk")
  logoUrl                    String?
  faviconUrl                 String?
  primaryColor               String   @default("#3b82f6")
  secondaryColor             String   @default("#1e40af")
  contactEmail               String?
  helpText                   String?
  enaUsername                String?
  enaPassword                String?
  enaTestMode                Boolean  @default(true)
  dataBasePath               String?
  postSubmissionInstructions String?
  modulesConfig              String?
  extraSettings              String?
  updatedAt                  DateTime @updatedAt
}

model OrderFormConfig {
  id              String   @id @default("singleton")
  schema          String
  coreFieldConfig String
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Submission {
  id               String   @id @default(cuid())
  submissionType   String
  status           String   @default("PENDING")
  xmlContent       String?
  response         String?
  accessionNumbers String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  entityType       String
  entityId         String
}

model DemoWorkspace {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  userId      String   @unique
  adminUserId String?  @unique
  seedVersion Int
  lastSeenAt  DateTime
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("DemoWorkspaceResearcher", fields: [userId], references: [id])
  adminUser   User?    @relation("DemoWorkspaceAdmin", fields: [adminUserId], references: [id])

  @@index([expiresAt])
}

model Ticket {
  id                 String          @id @default(cuid())
  subject            String
  status             String          @default("OPEN")
  priority           String          @default("NORMAL")
  lastUserMessageAt  DateTime?
  lastAdminMessageAt DateTime?
  userReadAt         DateTime?
  adminReadAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  closedAt           DateTime?
  userId             String
  orderId            String?
  studyId            String?
  user               User            @relation(fields: [userId], references: [id])
  order              Order?          @relation("TicketOrder", fields: [orderId], references: [id])
  study              Study?          @relation("TicketStudy", fields: [studyId], references: [id])
  messages           TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  userId    String
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model AdminInvite {
  id          String    @id @default(cuid())
  code        String    @unique
  email       String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  createdById String
  usedAt      DateTime?
  usedById    String?   @unique
  usedBy      User?     @relation("InviteUser", fields: [usedById], references: [id])
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id])
}
