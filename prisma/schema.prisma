generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  firstName      String
  lastName       String
  phone          String?
  role           String          @default("RESEARCHER")
  isDemo         Boolean         @default(false)
  researcherRole String?
  institution    String?
  facilityName   String?
  notificationPreferences String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  departmentId   String?
  demoWorkspace  DemoWorkspace?  @relation("DemoWorkspaceResearcher")
  adminDemoWorkspace DemoWorkspace? @relation("DemoWorkspaceAdmin")
  usedInvite     AdminInvite?    @relation("InviteUser")
  createdInvites AdminInvite[]   @relation("InviteCreator")
  orders         Order[]
  orderNotesEdited Order[]       @relation("OrderNotesEditor")
  sequencingFilesPublishedOrders Order[] @relation("OrderSequencingFilesPublisher")
  statusNotes    StatusNote[]
  studies          Study[]         @relation("StudyOwner")
  studyNotesEdited Study[]         @relation("StudyNotesEditor")
  tickets          Ticket[]
  ticketMessages TicketMessage[]
  pipelineRuns   PipelineRun[]
  pipelineResultSelectionsSelected PipelineResultSelection[] @relation("PipelineResultSelectedBy")
  inAppNotifications InAppNotification[]
  sequencingArtifactsCreated SequencingArtifact[] @relation("SequencingArtifactCreator")
  sequencingUploadsCreated   SequencingUpload[]   @relation("SequencingUploadCreator")
  backgroundWorkersStarted   BackgroundWorkerProcess[] @relation("BackgroundWorkerStartedBy")
  workbenchWorkspace WorkbenchWorkspace? @relation("WorkbenchWorkspaceOwner")
  workbenchImportJobsCreated WorkbenchImportJob[] @relation("WorkbenchImportJobCreator")
  department     Department?     @relation(fields: [departmentId], references: [id])
}

model InAppNotification {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType  String
  severity   String    @default("info")
  title      String
  body       String?
  linkPath   String?
  sourceType String
  sourceId   String?
  dedupeKey  String    @unique
  readAt     DateTime?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, archivedAt, readAt, createdAt])
  @@index([sourceType, sourceId])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model Order {
  id               String       @id @default(cuid())
  orderNumber      String       @unique
  name             String?
  generatedByE2E   Boolean      @default(false)
  status           String       @default("DRAFT")
  statusUpdatedAt  DateTime     @default(now())
  notes            String?
  notesEditedAt    DateTime?
  notesEditedById  String?
  sequencingFilesPublishedAt DateTime?
  sequencingFilesPublishedById String?
  numberOfSamples  Int?
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  billingAddress   String?
  platform         String?
  instrumentModel  String?
  librarySelection String?
  libraryStrategy  String?
  librarySource    String?
  customFields     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  notesEditedBy    User?        @relation("OrderNotesEditor", fields: [notesEditedById], references: [id])
  sequencingFilesPublishedBy User? @relation("OrderSequencingFilesPublisher", fields: [sequencingFilesPublishedById], references: [id], onDelete: SetNull)
  samples          Sample[]
  sequencingArtifacts SequencingArtifact[]
  sequencingUploads   SequencingUpload[]
  sequencingRuns      SequencingRun[]
  streamRuns          StreamRun[]
  pipelineRuns      PipelineRun[]
  pipelineResultSelections PipelineResultSelection[]
  sampleset        Sampleset?
  statusNotes      StatusNote[]
  tickets          Ticket[]     @relation("TicketOrder")
}

model Study {
  id                 String        @id @default(cuid())
  title              String
  alias              String?
  description        String?
  generatedByE2E     Boolean       @default(false)
  checklistType      String?
  studyMetadata      String?
  readyForSubmission Boolean       @default(false)
  readyAt            DateTime?
  studyAccessionId   String?
  submitted          Boolean       @default(false)
  submittedAt        DateTime?
  testRegisteredAt   DateTime?
  notes              String?
  notesEditedAt      DateTime?
  notesEditedById    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  userId             String
  samples            Sample[]
  pipelineRuns       PipelineRun[]
  pipelineResultSelections PipelineResultSelection[]
  user               User          @relation("StudyOwner", fields: [userId], references: [id])
  notesEditedBy      User?         @relation("StudyNotesEditor", fields: [notesEditedById], references: [id])
  tickets            Ticket[]      @relation("TicketStudy")
}

model Sampleset {
  id             String  @id @default(cuid())
  checklists     String
  selectedFields String?
  fieldOverrides String?
  sampleType     Int     @default(1)
  orderId        String  @unique
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Sample {
  id                    String     @id @default(cuid())
  sampleId              String
  sampleAlias           String?
  sampleTitle           String?
  sampleDescription     String?
  scientificName        String?
  taxId                 String?
  sampleAccessionNumber String?
  biosampleNumber       String?
  checklistData         String?
  checklistUnits        String?
  customFields          String?
  facilityStatus        String     @default("WAITING")
  facilityStatusUpdatedAt DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  orderId               String
  studyId               String?
  assemblies            Assembly[] @relation("SampleAssemblies")
  preferredAssemblyId   String?    @unique
  preferredAssembly     Assembly?  @relation("PreferredAssembly", fields: [preferredAssemblyId], references: [id], onDelete: SetNull)
  bins                  Bin[]
  reads                 Read[]
  sequencingRunSamples SequencingRunSample[]
  sequencingArtifacts   SequencingArtifact[]
  sequencingUploads     SequencingUpload[]
  streamIngestedFiles   StreamIngestedFile[]
  study                 Study?     @relation(fields: [studyId], references: [id])
  order                 Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Read {
  id                        String         @id @default(cuid())
  file1                     String?
  file2                     String?
  checksum1                 String?
  checksum2                 String?
  experimentAccessionNumber String?
  runAccessionNumber        String?
  readCount1                Int?
  readCount2                Int?
  avgQuality1               Float?
  avgQuality2               Float?
  fastqcReport1             String?
  fastqcReport2             String?
  sampleId                  String
  sequencingRunId           String?
  pipelineRunId             String?
  pipelineSources           String?
  dataClass                 String         @default("cleaned")
  dataClassSource           String         @default("legacy_assumed_cleaned")
  isActive                  Boolean        @default(true)
  supersededByReadId        String?
  classifiedAt              DateTime?
  classifiedById            String?
  classificationNote        String?
  sequencingRun             SequencingRun? @relation(fields: [sequencingRunId], references: [id])
  pipelineRun               PipelineRun?   @relation(fields: [pipelineRunId], references: [id], onDelete: SetNull)
  sample                    Sample         @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  @@index([sampleId, isActive])
  @@index([dataClass])
  @@index([supersededByReadId])
}

model SequencingRun {
  id             String    @id @default(cuid())
  runId          String
  runName        String?
  platform       String?
  instrument     String?
  runDate        DateTime?
  folderPath     String?
  q30Score       Float?
  clusterDensity Float?
  passFilterPct  Float?
  totalReads     Int?
  totalBases     BigInt?
  multiQcReport  String?
  demuxStats     String?
  runParameters  String?
  orderId        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  order          Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reads          Read[]
  samples        SequencingRunSample[]
  sequencingArtifacts SequencingArtifact[]

  @@unique([orderId, runId])
  @@index([orderId])
  @@index([runDate])
}

model SequencingRunSample {
  id               String        @id @default(cuid())
  sequencingRunId  String
  sampleId         String
  barcode          String?
  customFields     String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  sequencingRun    SequencingRun @relation(fields: [sequencingRunId], references: [id], onDelete: Cascade)
  sample           Sample        @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  @@unique([sequencingRunId, sampleId])
  @@unique([sequencingRunId, barcode])
  @@index([sampleId])
}

model StreamRun {
  id            String              @id @default(cuid())
  orderId       String
  minknowRunId  String?
  flowCellId    String?
  deviceId      String?
  outputDir     String
  status        String              @default("ACTIVE")
  totalBases    BigInt              @default(0)
  totalReads    Int                 @default(0)
  barcodeMap    String?
  startedAt     DateTime            @default(now())
  lastSeenAt    DateTime            @updatedAt
  stoppedAt     DateTime?
  monitorId     String?
  heartbeatAt   DateTime?
  order         Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events        StreamRunEvent[]
  ingestedFiles StreamIngestedFile[]

  @@index([orderId, status])
  @@index([status, heartbeatAt])
}

// Tracks every FASTQ file ingested into a stream run, with a unique constraint
// on (streamRunId, filePath) so chokidar re-emits (rename, atomic-write,
// duplicate add/change events) cannot double-count reads. The stream-monitor
// upserts here BEFORE incrementing StreamRun totals; if the upsert was a
// no-op (file already present), it skips the increment.
model StreamIngestedFile {
  id          String    @id @default(cuid())
  streamRunId String
  sampleId    String?
  filePath    String
  barcode     String?
  size        Int       @default(0)
  reads       Int       @default(0)
  bases       BigInt    @default(0)
  ingestedAt  DateTime  @default(now())
  streamRun   StreamRun @relation(fields: [streamRunId], references: [id], onDelete: Cascade)
  sample      Sample?   @relation(fields: [sampleId], references: [id], onDelete: SetNull)

  @@unique([streamRunId, filePath])
  @@index([streamRunId, ingestedAt])
  @@index([sampleId, ingestedAt])
}

model StreamRunEvent {
  id          String    @id @default(cuid())
  streamRunId String
  seq         Int       @default(autoincrement())
  ts          DateTime  @default(now())
  kind        String
  payload     String?
  streamRun   StreamRun @relation(fields: [streamRunId], references: [id], onDelete: Cascade)

  @@index([streamRunId, seq])
  @@index([streamRunId, ts])
}

model BackgroundWorkerProcess {
  id           String    @id @default(cuid())
  name         String
  pid          Int
  startedAt    DateTime  @default(now())
  startedById  String?
  status       String    @default("RUNNING")
  stoppedAt    DateTime?
  exitCode     Int?
  logPath      String
  lastErrorMsg String?
  startedBy    User?     @relation("BackgroundWorkerStartedBy", fields: [startedById], references: [id], onDelete: SetNull)

  @@index([name, status])
  @@index([name, startedAt])
}

model SequencingArtifact {
  id             String         @id @default(cuid())
  orderId        String
  sampleId       String?
  sequencingRunId String?
  stage          String
  artifactType   String
  source         String
  visibility     String         @default("facility")
  path           String
  originalName   String
  size           BigInt?
  checksum       String?
  mimeType       String?
  metadata       String?
  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sample         Sample?        @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  sequencingRun  SequencingRun? @relation(fields: [sequencingRunId], references: [id], onDelete: SetNull)
  createdBy      User?          @relation("SequencingArtifactCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([orderId, stage])
  @@index([sampleId, stage])
  @@index([sequencingRunId])
}

model SequencingUpload {
  id               String   @id @default(cuid())
  orderId          String
  sampleId         String?
  targetKind       String
  targetRole       String
  originalName     String
  tempPath         String
  finalPath        String?
  expectedSize     BigInt
  receivedSize     BigInt   @default(0)
  status           String   @default("PENDING")
  checksumProvided String?
  checksumComputed String?
  mimeType         String?
  metadata         String?
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sample           Sample?  @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  createdBy        User     @relation("SequencingUploadCreator", fields: [createdById], references: [id])

  @@index([orderId, status])
  @@index([sampleId, status])
}

model Assembly {
  id                     String       @id @default(cuid())
  assemblyName           String?
  assemblyFile           String?
  assemblyAccession      String?
  sampleId               String
  sample                 Sample       @relation("SampleAssemblies", fields: [sampleId], references: [id], onDelete: Cascade)
  preferredBySample      Sample?      @relation("PreferredAssembly")
  // Track which pipeline created this assembly
  createdByPipelineRunId String?
  createdByPipelineRun   PipelineRun? @relation(fields: [createdByPipelineRunId], references: [id])
}

model Bin {
  id                     String       @id @default(cuid())
  binName                String?
  binAccession           String?
  binFile                String?
  completeness           Float?
  contamination          Float?
  sampleId               String
  sample                 Sample       @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  // Track which pipeline created this bin
  createdByPipelineRunId String?
  createdByPipelineRun   PipelineRun? @relation(fields: [createdByPipelineRunId], references: [id])
}

// ============================================================================
// PIPELINE SYSTEM
// ============================================================================

// Pipeline configuration (enabled/disabled + settings per pipeline type)
model PipelineConfig {
  id         String   @id @default(cuid())
  pipelineId String   @unique // 'mag', 'submg', 'fastqc'
  enabled    Boolean  @default(false)
  config     String? // JSON: pipeline-specific settings
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Individual pipeline execution record
model PipelineRun {
  id         String @id @default(cuid())
  runNumber  String @unique // MAG-20240126-001
  pipelineId String // 'mag', 'submg', 'fastqc'
  status     String @default("pending") // pending, queued, running, completed, failed, cancelled
  targetType String @default("study") // study, order

  // Configuration snapshot at run time
  config         String? // JSON
  inputSampleIds String? // JSON array of sample IDs selected for this run

  // Input - which study this run is for
  studyId String?
  study   Study?  @relation(fields: [studyId], references: [id])
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  // Execution details
  runFolder   String? // Path to run directory
  queueJobId  String? // SLURM job ID or task queue ID
  executionMode String? // resolved execution target: local, slurm
  executionProfile String? // JSON snapshot of non-secret execution policy used for this run
  progress    Int? // 0-100
  currentStep String? // "Running MEGAHIT..."

  // Timing
  queuedAt     DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  lastEventAt  DateTime?
  lastWeblogAt DateTime?
  lastTraceAt  DateTime?
  statusSource String? // weblog, trace, process, launcher

  // Logs (stored as paths for large outputs)
  outputPath String? // Path to stdout file
  errorPath  String? // Path to stderr file
  outputTail String? // Last ~100 lines of output for quick preview
  errorTail  String? // Last ~100 lines of error

  // Results summary
  results String? // JSON summary of outputs

  // Queue tracking (SLURM/local)
  queueStatus    String? // RUNNING, PENDING, etc.
  queueReason    String?
  queueUpdatedAt DateTime?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Who started this run
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Track outputs created by this run
  assembliesCreated Assembly[]
  binsCreated       Bin[]
  readsCreated      Read[]
  steps             PipelineRunStep[]
  events            PipelineRunEvent[]
  artifacts         PipelineArtifact[]
  selectedResultSelections PipelineResultSelection[] @relation("SelectedPipelineResultRun")

  @@index([studyId])
  @@index([orderId])
  @@index([targetType])
}

// Individual step within a pipeline run (for DAG visualization)
model PipelineRunStep {
  id            String      @id @default(cuid())
  pipelineRunId String
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  stepId        String // e.g., "FASTQC", "MEGAHIT", "METABAT2" - from Nextflow process names
  stepName      String? // Human-readable name
  status        String      @default("pending") // pending, running, completed, failed, skipped
  startedAt     DateTime?
  completedAt   DateTime?
  outputPath    String?
  errorPath     String?
  outputTail    String? // Last lines of output
  errorTail     String? // Last lines of error

  @@unique([pipelineRunId, stepId])
}

// Event feed for pipeline runs (weblog/trace/queue updates)
model PipelineRunEvent {
  id            String      @id @default(cuid())
  pipelineRunId String
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  eventType     String
  processName   String?
  stepId        String?
  status        String?
  message       String?
  payload       String? // JSON (trimmed)
  source        String? // weblog, trace, queue, process
  occurredAt    DateTime    @default(now())

  @@index([pipelineRunId, occurredAt])
}

// Artifacts produced by pipeline runs (files, reports, etc.)
model PipelineArtifact {
  id               String       @id @default(cuid())
  type             String // "reads", "assembly", "bins", "qc_report", "alignment"
  name             String? // Display name
  path             String // Absolute or relative path to artifact
  checksum         String? // MD5 or SHA256
  size             BigInt? // File size in bytes
  outputId         String? // Manifest output id, when resolved from a package output
  studyId          String?
  sampleId         String?
  pipelineRunId    String?
  pipelineRun      PipelineRun? @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  producedByStepId String? // Which step produced this
  metadata         String? // JSON for tool-specific info
  createdAt        DateTime     @default(now())

  @@index([outputId])
}

// Explicit final-result selection for one study/order target and pipeline.
model PipelineResultSelection {
  id            String      @id @default(cuid())
  pipelineId    String
  targetKey     String // study:<id> or order:<id>
  studyId       String?
  orderId       String?
  selectedRunId String      @unique
  selectedRun   PipelineRun @relation("SelectedPipelineResultRun", fields: [selectedRunId], references: [id], onDelete: Cascade)
  selectedById  String?
  selectedBy    User?       @relation("PipelineResultSelectedBy", fields: [selectedById], references: [id], onDelete: SetNull)
  study         Study?      @relation(fields: [studyId], references: [id], onDelete: Cascade)
  order         Order?      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  selectedAt    DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([pipelineId, targetKey])
  @@index([studyId])
  @@index([orderId])
  @@index([selectedById])
}

// ============================================================================
// WORKBENCH DATA IMPORTS
// ============================================================================

model WorkbenchWorkspace {
  id        String   @id @default(cuid())
  name      String   @default("Private Workbench")
  ownerId   String   @unique
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner      User                         @relation("WorkbenchWorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  datasets   WorkbenchWorkspaceDataset[]
  importJobs WorkbenchImportJob[]
  analyses   WorkbenchAnalysis[]

  @@index([ownerId])
}

model WorkbenchAnalysis {
  id          String   @id @default(cuid())
  workspaceId String
  name        String   @default("Untitled analysis")
  description String?
  canvas      String
  revision    Int      @default(1)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace  WorkbenchWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importJobs WorkbenchImportJob[]

  @@index([workspaceId, updatedAt])
  @@index([workspaceId, isDefault])
}

model WorkbenchDataset {
  id             String   @id @default(cuid())
  providerId     String
  cacheKey       String   @unique
  name           String
  description    String?
  sourceType     String
  sourceMetadata String?
  storagePath    String?
  sizeBytes      BigInt?
  checksumSha256 String?
  genomeCount    Int?
  status         String   @default("ready")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspaces WorkbenchWorkspaceDataset[]
  importJobs  WorkbenchImportJob[]

  @@index([providerId])
  @@index([status])
}

model WorkbenchWorkspaceDataset {
  id                   String   @id @default(cuid())
  workspaceId          String
  datasetId            String
  createdByImportJobId String?
  linkedAt             DateTime @default(now())

  workspace          WorkbenchWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dataset            WorkbenchDataset   @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  createdByImportJob WorkbenchImportJob? @relation(fields: [createdByImportJobId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, datasetId])
  @@index([datasetId])
  @@index([createdByImportJobId])
}

model WorkbenchImportJob {
  id              String   @id @default(cuid())
  workspaceId     String
  providerId      String
  status          String   @default("queued")
  phase           String?
  request         String
  preview         String?
  progress        Int?
  logPath         String?
  targetPath      String?
  error           String?
  createdById     String
  resultDatasetId String?
  analysisId      String?
  analysisNodeId  String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       WorkbenchWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User               @relation("WorkbenchImportJobCreator", fields: [createdById], references: [id], onDelete: Cascade)
  resultDataset   WorkbenchDataset?  @relation(fields: [resultDatasetId], references: [id], onDelete: SetNull)
  analysis        WorkbenchAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  workspaceLinks  WorkbenchWorkspaceDataset[]

  @@index([workspaceId, createdAt])
  @@index([providerId])
  @@index([status])
  @@index([createdById])
  @@index([resultDatasetId])
  @@index([analysisId])
}

model StatusNote {
  id        String   @id @default(cuid())
  noteType  String   @default("INTERNAL")
  content   String
  createdAt DateTime @default(now())
  orderId   String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model SiteSettings {
  id                         String   @id @default("singleton")
  siteName                   String   @default("SeqDesk")
  logoUrl                    String?
  faviconUrl                 String?
  primaryColor               String   @default("#3b82f6")
  secondaryColor             String   @default("#1e40af")
  contactEmail               String?
  helpText                   String?
  enaUsername                String?
  enaPassword                String?
  enaTestMode                Boolean  @default(true)
  dataBasePath               String?
  postSubmissionInstructions String?
  modulesConfig              String?
  extraSettings              String?
  updatedAt                  DateTime @updatedAt
}

model OrderFormConfig {
  id              String   @id @default("singleton")
  schema          String
  coreFieldConfig String
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Submission {
  id               String   @id @default(cuid())
  submissionType   String
  status           String   @default("PENDING")
  xmlContent       String?
  response         String?
  accessionNumbers String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  entityType       String
  entityId         String
}

model DemoWorkspace {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  userId      String   @unique
  adminUserId String?  @unique
  seedVersion Int
  lastSeenAt  DateTime
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("DemoWorkspaceResearcher", fields: [userId], references: [id])
  adminUser   User?    @relation("DemoWorkspaceAdmin", fields: [adminUserId], references: [id])

  @@index([expiresAt])
}

model Ticket {
  id                 String          @id @default(cuid())
  subject            String
  status             String          @default("OPEN")
  priority           String          @default("NORMAL")
  lastUserMessageAt  DateTime?
  lastAdminMessageAt DateTime?
  userReadAt         DateTime?
  adminReadAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  closedAt           DateTime?
  userId             String
  orderId            String?
  studyId            String?
  user               User            @relation(fields: [userId], references: [id])
  order              Order?          @relation("TicketOrder", fields: [orderId], references: [id])
  study              Study?          @relation("TicketStudy", fields: [studyId], references: [id])
  messages           TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  userId    String
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model AdminInvite {
  id          String    @id @default(cuid())
  code        String    @unique
  email       String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  createdById String
  usedAt      DateTime?
  usedById    String?   @unique
  usedBy      User?     @relation("InviteUser", fields: [usedById], references: [id])
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id])
}
