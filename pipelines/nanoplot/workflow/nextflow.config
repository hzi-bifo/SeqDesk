// Minimal local config. SeqDesk synthesizes the run-specific config (conda
// channels, cacheDir, profiles, resource overrides) at run time and passes it
// with `-c`, so this file only declares workflow defaults.
nextflow.enable.dsl = 2

manifest {
  name = 'nanoplot'
  description = 'Long-read QC with NanoPlot (Oxford Nanopore / PacBio)'
  version = '0.1.0'
  mainScript = 'main.nf'
}

params {
  input = null
  outdir = 'output'
}
