manifest {
  name = "hzi-bifo/MetaxPath"
  author = "hzi-bifo"
  homePage = "https://github.com/hzi-bifo/MetaxPath"
  description = "MetaxPath Nextflow port (draft) for long-read pathogen profiling, virulence and AMR analysis."
  version = "0.1.0"
}

params {
  input = null
  outdir = "results"

  sequencer = "Nanopore"
  assemblers = "flye"
  threads = 20
  topn = 50

  skip_sylph = false
  skip_virulence = false
  skip_amr = false

  metax_db = ""
  metax_dmp_dir = ""
  kraken2_db = ""
  sylph_db = ""
  ref_index = ""
  notification_emails = ""

  humanvirus = "${projectDir}/data/virus/human_virus_taxids.txt"
  contamination_table = "${projectDir}/data/contamination/skin.contamination.taxa.txt"
  vfdb_core = "${projectDir}/data/VFDB/VFDB_setA_nt.fa"

  run_date = null
}

process {
  shell = ["/bin/bash", "-euo", "pipefail"]
  executor = "local"
  cpus = 2
  memory = "8 GB"
  errorStrategy = "terminate"
  maxRetries = 0

  withName: INPUT_CHECK {
    cpus = 1
    memory = "1 GB"
    conda = "${projectDir}/config/base.env.yaml"
  }

  withName: MV_FASTQ {
    cpus = 1
    memory = "1 GB"
    conda = "${projectDir}/config/base.env.yaml"
  }

  withName: METAX_PROFILE {
    cpus = { params.threads as int }
    memory = "16 GB"
    conda = "${projectDir}/config/metax.env.yaml"
  }

  withName: SAM2BAM {
    cpus = 4
    memory = "4 GB"
    conda = "${projectDir}/config/base.env.yaml"
  }

  withName: SYLPH_PROFILE {
    cpus = { params.threads as int }
    memory = "8 GB"
    conda = "${projectDir}/config/base.env.yaml"
  }

  withName: PROCESS_METAX {
    cpus = 2
    memory = "4 GB"
    conda = "${projectDir}/config/metax.env.yaml"
  }

  withName: PRED_VFS_AMRS {
    cpus = { params.threads as int }
    memory = "32 GB"
    conda = "${projectDir}/config/base.env.yaml"
  }

  withName: MATCH_PROFILE_VFS_AMRS {
    cpus = 1
    memory = "2 GB"
    conda = "${projectDir}/config/base.env.yaml"
  }

  withName: GENERATE_READCOUNT_STATS {
    cpus = 1
    memory = "2 GB"
    conda = "${projectDir}/config/base.env.yaml"
  }

  withName: GENERATE_PROFILE_REPORT {
    cpus = 2
    memory = "8 GB"
    conda = "${projectDir}/config/base.env.yaml"
  }

  withName: DOTPLOT {
    cpus = 1
    memory = "4 GB"
    conda = "${projectDir}/config/base.env.yaml"
  }

  withName: CLEAN_REPORT {
    cpus = 1
    memory = "2 GB"
    conda = "${projectDir}/config/base.env.yaml"
  }

  withName: CLEAN_DOTPLOT {
    cpus = 1
    memory = "4 GB"
    conda = "${projectDir}/config/base.env.yaml"
  }
}

profiles {
  conda {
    conda.enabled = true
    docker.enabled = false
    singularity.enabled = false
  }

  standard {
    conda.enabled = false
  }
}
