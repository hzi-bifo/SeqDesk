{
  "pipeline": "metaxpath",
  "name": "MetaxPath (Hosted Nextflow)",
  "description": "Long-read clinical metagenomics workflow for taxonomic profiling, virulence factor search, and AMR prediction.",
  "url": "https://github.com/hzi-bifo/MetaxPath",
  "version": "0.1.0",
  "minNextflowVersion": "23.10.0",
  "authors": [
    "hzi-bifo"
  ],
  "inputs": [
    {
      "id": "long_reads",
      "name": "Long Reads",
      "description": "Per-sample long-read FASTQ files (Nanopore or PacBio).",
      "fileTypes": [
        "fastq.gz",
        "fq.gz",
        "fastq",
        "fq"
      ],
      "source": "order_reads",
      "sourceDescription": "SeqDesk sample read assignments."
    },
    {
      "id": "samplesheet",
      "name": "Samplesheet",
      "description": "Auto-generated CSV with sample ID, long read path, and sequencer.",
      "fileTypes": [
        "csv"
      ],
      "source": "samplesheet",
      "sourceDescription": "Generated from pipelines/metaxpath/samplesheet.yaml."
    }
  ],
  "outputs": [
    {
      "id": "sample_profile",
      "name": "Per-sample Profile with VFs/AMRs",
      "description": "Sample-level merged profile table including virulence and AMR annotations.",
      "fromStep": "merge_profiles",
      "fileTypes": [
        "txt"
      ],
      "destination": "sample_metadata",
      "destinationDescription": "Stored as sample-scoped pipeline artifact."
    },
    {
      "id": "combined_report_html",
      "name": "Combined HTML Report",
      "description": "Top-N aggregated report across samples.",
      "fromStep": "report_html",
      "fileTypes": [
        "html"
      ],
      "destination": "study_report",
      "destinationDescription": "Stored as study-level report artifact."
    },
    {
      "id": "combined_readcount_stats",
      "name": "Readcount Summary",
      "description": "Combined readcount summary for run-level QC visibility.",
      "fromStep": "readcount_stats",
      "fileTypes": [
        "txt"
      ],
      "destination": "study_report",
      "destinationDescription": "Stored as study-level report artifact."
    },
    {
      "id": "dotplots",
      "name": "Dotplot PDFs",
      "description": "Species and cleaned-species dotplot visualizations.",
      "fromStep": "dotplot",
      "fileTypes": [
        "pdf"
      ],
      "destination": "study_report",
      "destinationDescription": "Stored as study-level report artifact."
    },
    {
      "id": "run_logs",
      "name": "Run Logs and Benchmarks",
      "description": "Per-sample logs and benchmark files from VF/AMR prediction.",
      "fromStep": "amr_virulence_prediction",
      "fileTypes": [
        "log",
        "bench",
        "txt"
      ],
      "destination": "run_artifact",
      "destinationDescription": "Stored as run-scoped artifacts."
    }
  ],
  "parameterGroups": [
    {
      "name": "Core Runtime",
      "description": "Main runtime knobs to align with the current Snakemake behavior.",
      "parameters": [
        {
          "name": "sequencer",
          "type": "string",
          "description": "Input sequencer type.",
          "default": "Nanopore",
          "enum": [
            "Nanopore",
            "PacBio"
          ]
        },
        {
          "name": "assemblers",
          "type": "string",
          "description": "Comma-separated assembler list (flye,myloasm).",
          "default": "flye"
        },
        {
          "name": "threads",
          "type": "integer",
          "description": "Global thread cap for heavy tasks.",
          "default": 20,
          "minimum": 1
        },
        {
          "name": "topn",
          "type": "integer",
          "description": "Top species count for final report generation.",
          "default": 50,
          "minimum": 1
        }
      ]
    },
    {
      "name": "Databases",
      "description": "External database paths required by MetaxPath.",
      "parameters": [
        {
          "name": "metaxDb",
          "type": "string",
          "description": "Metax database prefix path (without .json extension)."
        },
        {
          "name": "metaxDmpDir",
          "type": "string",
          "description": "NCBI taxonomy dump directory for Metax."
        },
        {
          "name": "kraken2Db",
          "type": "string",
          "description": "Kraken2 database path."
        },
        {
          "name": "sylphDb",
          "type": "string",
          "description": "Sylph database path or glob."
        },
        {
          "name": "vfdbCore",
          "type": "string",
          "description": "Optional VFDB FASTA path. If empty, the bundled workflow default is used."
        },
        {
          "name": "refIndex",
          "type": "string",
          "description": "Host reference minimap2 index."
        }
      ]
    }
  ],
  "steps": [
    {
      "id": "input",
      "name": "Input Validation",
      "description": "Validate samplesheet rows, long-read file presence, and mandatory database parameters.",
      "category": "qc",
      "dependsOn": [],
      "processMatchers": [
        "INPUT_CHECK"
      ],
      "outputs": [
        "samplesheet.csv"
      ]
    },
    {
      "id": "move_fastq",
      "name": "Prepare No-Human FASTQ",
      "description": "Materialize per-sample no-human FASTQ and read stats files used downstream.",
      "category": "preprocessing",
      "dependsOn": [
        "input"
      ],
      "processMatchers": [
        "MV_FASTQ"
      ],
      "outputs": [
        "*.nohuman.fq.gz",
        "*.nohuman_fract.stats"
      ]
    },
    {
      "id": "metax_profile",
      "name": "Metax Profiling",
      "description": "Run Metax profiling in recall mode against configured databases.",
      "category": "quantification",
      "dependsOn": [
        "move_fastq"
      ],
      "processMatchers": [
        "METAX_PROFILE"
      ],
      "outputs": [
        "*.metax.sam",
        "*.metax.profile.txt"
      ]
    },
    {
      "id": "metax_bam",
      "name": "SAM to BAM",
      "description": "Convert Metax SAM output to BAM and remove intermediate SAM.",
      "category": "alignment",
      "dependsOn": [
        "metax_profile"
      ],
      "processMatchers": [
        "SAM2BAM"
      ],
      "outputs": [
        "*.metax.bam"
      ]
    },
    {
      "id": "sylph_profile",
      "name": "Sylph Profiling",
      "description": "Sketch and profile reads with Sylph for complementary taxonomic signals.",
      "category": "quantification",
      "dependsOn": [
        "move_fastq"
      ],
      "processMatchers": [
        "SYLPH_PROFILE"
      ],
      "outputs": [
        "*.sylph.profile.txt"
      ]
    },
    {
      "id": "process_metax",
      "name": "Process Metax Profiles",
      "description": "Filter Metax output and annotate contamination and human-virus content.",
      "category": "preprocessing",
      "dependsOn": [
        "metax_profile"
      ],
      "processMatchers": [
        "PROCESS_METAX"
      ],
      "outputs": [
        "*.metax.processed.profile.txt",
        "*.metax.processed.filtered.profile.txt"
      ]
    },
    {
      "id": "amr_virulence_prediction",
      "name": "Assembly, VF and AMR Prediction",
      "description": "Run assembler branch and VF/AMR prediction script per sample and assembler.",
      "category": "annotation",
      "dependsOn": [
        "process_metax"
      ],
      "processMatchers": [
        "PRED_VFS_AMRS",
        "MAG_VF_AMR"
      ],
      "outputs": [
        "assembly.done",
        "mags.done",
        "blast_vfs_summary.txt",
        "predict_amrs_summary.txt"
      ]
    },
    {
      "id": "merge_profiles",
      "name": "Merge Profiles with VF/AMR",
      "description": "Join filtered Metax profile with virulence and AMR summaries.",
      "category": "annotation",
      "dependsOn": [
        "process_metax",
        "amr_virulence_prediction"
      ],
      "processMatchers": [
        "MATCH_PROFILE_VFS_AMRS"
      ],
      "outputs": [
        "*.profile.with_vfs_amrs.txt"
      ]
    },
    {
      "id": "readcount_stats",
      "name": "Generate Readcount Stats",
      "description": "Combine sample-level readcount statistics into a run summary.",
      "category": "reporting",
      "dependsOn": [
        "process_metax"
      ],
      "processMatchers": [
        "GENERATE_READCOUNT_STATS"
      ],
      "outputs": [
        "metaxpath.combined_readcount_stats.txt"
      ]
    },
    {
      "id": "report_html",
      "name": "Generate Combined Report",
      "description": "Build top-N combined report in text and HTML formats.",
      "category": "reporting",
      "dependsOn": [
        "merge_profiles"
      ],
      "processMatchers": [
        "GENERATE_PROFILE_REPORT"
      ],
      "outputs": [
        "metaxpath.combined_report.top50.txt",
        "metaxpath.combined_report.top50.html",
        "metaxpath.combined_report.simple.txt"
      ]
    },
    {
      "id": "dotplot",
      "name": "Dotplot Rendering",
      "description": "Render species abundance dotplot PDF from simple report output.",
      "category": "reporting",
      "dependsOn": [
        "report_html"
      ],
      "processMatchers": [
        "DOTPLOT"
      ],
      "outputs": [
        "metaxpath.combined_report.simple.dotplot.pdf"
      ]
    },
    {
      "id": "clean_report",
      "name": "Clean Species Report",
      "description": "Generate cleaned species-only report variants used for downstream plotting.",
      "category": "reporting",
      "dependsOn": [
        "report_html"
      ],
      "processMatchers": [
        "CLEAN_REPORT"
      ],
      "outputs": [
        "metaxpath.combined_report.species_cleaned.top50.txt",
        "metaxpath.combined_report.species_cleaned.simple.txt"
      ]
    },
    {
      "id": "clean_dotplot",
      "name": "Clean Species Dotplot",
      "description": "Render cleaned species dotplot PDF.",
      "category": "reporting",
      "dependsOn": [
        "clean_report"
      ],
      "processMatchers": [
        "CLEAN_DOTPLOT"
      ],
      "outputs": [
        "metaxpath.combined_report.species_cleaned.simple.dotplot.pdf"
      ]
    }
  ]
}
