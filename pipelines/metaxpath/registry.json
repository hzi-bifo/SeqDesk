{
  "id": "metaxpath",
  "name": "MetaxPath",
  "description": "Hosted MetaxPath package with an in-repo Nextflow workflow and SeqDesk output integration.",
  "category": "analysis",
  "version": "0.1.0",
  "website": "https://github.com/hzi-bifo/MetaxPath",
  "requires": {
    "reads": true,
    "assemblies": false,
    "bins": false,
    "checksums": false,
    "studyAccession": false,
    "sampleMetadata": false
  },
  "outputs": [
    {
      "type": "metric",
      "name": "sample_profile",
      "description": "Per-sample merged profile with VF and AMR annotations.",
      "visibility": "both",
      "downloadable": true
    },
    {
      "type": "report",
      "name": "combined_report_html",
      "description": "Combined top-N pathogen report in HTML format.",
      "visibility": "both",
      "downloadable": true
    },
    {
      "type": "report",
      "name": "combined_readcount_stats",
      "description": "Combined readcount statistics across samples.",
      "visibility": "both",
      "downloadable": true
    },
    {
      "type": "report",
      "name": "dotplots",
      "description": "Dotplot PDFs for species abundance and cleaned species report.",
      "visibility": "both",
      "downloadable": true
    },
    {
      "type": "data",
      "name": "run_logs",
      "description": "Per-sample logs and benchmark traces.",
      "visibility": "admin",
      "downloadable": true
    }
  ],
  "visibility": {
    "showToUser": true,
    "userCanStart": false
  },
  "input": {
    "supportedScopes": [
      "study",
      "samples"
    ],
    "minSamples": 1,
    "perSample": {
      "reads": true,
      "pairedEnd": false
    }
  },
  "samplesheet": {
    "format": "csv",
    "generator": "samplesheet.yaml"
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "sequencer": {
        "type": "string",
        "title": "Sequencer",
        "description": "Select long-read sequencing platform.",
        "default": "Nanopore",
        "enum": [
          "Nanopore",
          "PacBio"
        ]
      },
      "assemblers": {
        "type": "string",
        "title": "Assemblers",
        "description": "Comma-separated list: flye,myloasm.",
        "default": "flye"
      },
      "threads": {
        "type": "number",
        "title": "Threads",
        "description": "Global thread limit for compute-heavy tools.",
        "default": 20
      },
      "topn": {
        "type": "number",
        "title": "Top N Report Rows",
        "description": "Number of top species to keep in the combined report.",
        "default": 50
      },
      "metaxDb": {
        "type": "string",
        "title": "Metax DB",
        "description": "Path prefix to Metax database (without .json suffix).",
        "default": ""
      },
      "metaxDmpDir": {
        "type": "string",
        "title": "Metax Taxdump Directory",
        "description": "Path to NCBI taxonomy dump directory used by Metax.",
        "default": ""
      },
      "kraken2Db": {
        "type": "string",
        "title": "Kraken2 DB",
        "description": "Path to Kraken2 database.",
        "default": ""
      },
      "sylphDb": {
        "type": "string",
        "title": "Sylph DB",
        "description": "Path or glob for Sylph database files.",
        "default": ""
      },
      "vfdbCore": {
        "type": "string",
        "title": "VFDB Core FASTA",
        "description": "Optional path to VFDB core BLAST database FASTA (overrides bundled default).",
        "default": ""
      },
      "refIndex": {
        "type": "string",
        "title": "Host Reference Index",
        "description": "Path to minimap2 host reference index (.mmi).",
        "default": ""
      },
      "skipSylph": {
        "type": "boolean",
        "title": "Skip Sylph",
        "description": "Disable Sylph branch.",
        "default": false
      },
      "skipVirulence": {
        "type": "boolean",
        "title": "Skip Virulence Search",
        "description": "Disable VFDB BLAST virulence detection.",
        "default": false
      },
      "skipAmr": {
        "type": "boolean",
        "title": "Skip AMR Prediction",
        "description": "Disable ResFinder and Kover AMR prediction branch.",
        "default": false
      },
      "notificationEmails": {
        "type": "string",
        "title": "Notification Emails",
        "description": "Comma-separated list of email addresses.",
        "default": ""
      }
    }
  },
  "defaultConfig": {
    "sequencer": "Nanopore",
    "assemblers": "flye",
    "threads": 20,
    "topn": 50,
    "metaxDb": "",
    "metaxDmpDir": "",
    "kraken2Db": "",
    "sylphDb": "",
    "vfdbCore": "",
    "refIndex": "",
    "skipSylph": false,
    "skipVirulence": false,
    "skipAmr": false,
    "notificationEmails": ""
  },
  "icon": "Dna"
}
