// Minimal manifest/defaults for the local kraken2-bracken workflow.
// SeqDesk synthesizes the run-specific config (conda channels, cacheDir,
// resource limits, profiles) at run time and layers it via `-c`, so this
// file intentionally only declares the workflow manifest and parameter
// defaults. Do not add conda{}/profiles{} blocks here.

manifest {
  name = 'kraken2-bracken'
  description = 'Taxonomic profiling with Kraken2, Bracken and Krona'
  version = '0.1.0'
  mainScript = 'main.nf'
  nextflowVersion = '>=23.04.0'
}

params {
  input = null
  outdir = 'output'
  kraken2_db = null
  confidence = 0.0
  bracken_read_length = 150
  bracken_level = 'S'
  krona = true
}
