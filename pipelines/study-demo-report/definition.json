{
  "pipeline": "study-demo-report",
  "name": "Study Demo Report",
  "description": "Generate deterministic study-level HTML, Markdown, and TSV outputs",
  "version": "0.1.0",
  "inputs": [
    {
      "id": "samplesheet",
      "name": "Study samplesheet",
      "description": "Sample identifiers and study metadata generated by SeqDesk",
      "fileTypes": [
        ".csv"
      ],
      "source": "generated_samplesheet",
      "sourceDescription": "SeqDesk-generated study samplesheet"
    }
  ],
  "outputs": [
    {
      "id": "html_report",
      "name": "HTML report",
      "description": "Browser-rendered demo report",
      "fromStep": "demo_report",
      "fileTypes": [
        ".html"
      ],
      "destination": "study_report",
      "destinationDescription": "Stored as a study-level report"
    },
    {
      "id": "markdown_report",
      "name": "Markdown report",
      "description": "Markdown report for in-app preview testing",
      "fromStep": "demo_report",
      "fileTypes": [
        ".md"
      ],
      "destination": "run_artifact",
      "destinationDescription": "Stored as a run artifact"
    },
    {
      "id": "sample_summary",
      "name": "Sample summary table",
      "description": "TSV table with one row per sample",
      "fromStep": "demo_report",
      "fileTypes": [
        ".tsv"
      ],
      "destination": "run_artifact",
      "destinationDescription": "Stored as a run artifact"
    }
  ],
  "steps": [
    {
      "id": "demo_report",
      "name": "Build Demo Report",
      "description": "Summarize the SeqDesk samplesheet into small example outputs",
      "category": "reporting",
      "dependsOn": [],
      "processMatchers": [
        "BUILD_DEMO_REPORT"
      ],
      "tools": [
        "awk"
      ],
      "outputs": [
        "demo-report.html",
        "demo-report.md",
        "sample-summary.tsv"
      ]
    }
  ]
}
