// Minimal local config for the Study MultiQC workflow.
//
// SeqDesk synthesizes the authoritative run config at launch time and passes it
// with `-c <runConfig>` (conda channels/profile/cacheDir, resource overrides,
// trace/report/timeline). That `-c` config is merged on top of this file, so
// keep only workflow-local defaults here.

manifest {
  name = 'multiqc'
  description = 'Aggregate prior study QC outputs into a single MultiQC report'
  version = '0.1.0'
  mainScript = 'main.nf'
  nextflowVersion = '>=23.04.0'
}

params {
  input = null
  outdir = 'output'
  report_title = 'Study MultiQC report'
  qc_dir = null
}
