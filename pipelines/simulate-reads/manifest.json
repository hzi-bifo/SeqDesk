{
  "manifestVersion": 1,
  "package": {
    "id": "simulate-reads",
    "name": "Simulate Reads",
    "version": "0.2.0",
    "description": "Generate dummy FASTQ data for the samples in an order",
    "provider": "SeqDesk"
  },
  "files": {
    "definition": "definition.json",
    "registry": "registry.json",
    "samplesheet": "samplesheet.yaml",
    "readme": "README.md",
    "scripts": {
      "discoverOutputs": "scripts/discover-outputs.mjs"
    }
  },
  "targets": {
    "supported": [
      "order"
    ]
  },
  "inputs": [],
  "execution": {
    "type": "nextflow",
    "pipeline": "./workflow",
    "version": "0.2.0",
    "profiles": [
      "conda"
    ],
    "runtime": {
      "allowMacOsArmConda": true
    },
    "defaultParams": {
      "simulationMode": "auto",
      "mode": "shortReadPaired",
      "readCount": 1000,
      "readLength": 150,
      "replaceExisting": true,
      "qualityProfile": "standard",
      "insertMean": 350,
      "insertStdDev": 30,
      "seed": null,
      "templateDir": ""
    }
  },
  "outputs": [
    {
      "id": "sample_simulated_reads",
      "scope": "sample",
      "destination": "sample_reads",
      "type": "artifact",
      "fromStep": "simulate_reads",
      "writeback": {
        "target": "Read",
        "mode": "replace",
        "fields": {
          "file1": "file1",
          "file2": "file2",
          "readCount1": "readCount1",
          "readCount2": "readCount2"
        }
      },
      "discovery": {
        "pattern": "manifests/*.json",
        "matchSampleBy": "filename"
      }
    },
    {
      "id": "summary",
      "scope": "run",
      "destination": "run_artifact",
      "type": "artifact",
      "fromStep": "simulate_reads",
      "discovery": {
        "pattern": "summary/simulation-summary.tsv"
      }
    }
  ],
  "schema_requirements": {
    "tables": [
      "Read",
      "PipelineRun",
      "PipelineArtifact"
    ]
  }
}
