{
  "_comment": "Repository-development example. Copy to seqdesk.config.json; installed releases use settings.json and default to port 8000.",

  "app": {
    "port": 3000
  },

  "site": {
    "name": "My Sequencing Facility",
    "dataBasePath": "./data/sequencing",
    "contactEmail": "sequencing@example.com"
  },

  "pipelines": {
    "enabled": false,
    "execution": {
      "mode": "local",
      "runDirectory": "./data/pipeline-runs",
      "conda": {
        "path": "/opt/conda",
        "environment": "seqdesk-pipelines"
      },
      "slurm": {
        "enabled": false,
        "queue": "cpu",
        "cores": 4,
        "memory": "64GB",
        "timeLimit": 12,
        "options": ""
      }
    },
    "mag": {
      "enabled": true,
      "version": "3.4.0",
      "stubMode": false,
      "skipProkka": true,
      "skipConcoct": true
    }
  },

  "ena": {
    "testMode": true,
    "centerName": "My Center"
  },

  "sequencingFiles": {
    "extensions": [".fastq.gz", ".fq.gz", ".fastq", ".fq"],
    "scanDepth": 2,
    "ignorePatterns": ["**/tmp/**", "**/undetermined/**"],
    "simulationMode": "auto",
    "simulationTemplateDir": "_simulation_templates/mag"
  },

  "auth": {
    "allowRegistration": true
  },

  "telemetry": {
    "enabled": false,
    "endpoint": "https://seqdesk.org/api/telemetry/heartbeat",
    "intervalHours": 24
  },

  "notifications": {
    "enabled": false,
    "provider": "seqdesk-relay",
    "relayUrl": "https://seqdesk.org/api/notifications/relay",
    "relayToken": "",
    "events": {
      "order": {
        "submitted": true,
        "statusChanged": true,
        "samplesSent": true
      },
      "ticket": {
        "created": true,
        "reply": true
      }
    },
    "userDefaults": {
      "orders": true,
      "support": true
    }
  },

  "runtime": {
    "databaseUrl": "postgresql://seqdesk:replace-with-local-db-password@127.0.0.1:5432/seqdesk?schema=public",
    "directUrl": "postgresql://seqdesk:replace-with-local-db-password@127.0.0.1:5432/seqdesk?schema=public",
    "nextAuthUrl": "http://localhost:3000",
    "nextAuthSecret": "",
    "anthropicApiKey": "",
    "adminSecret": "",
    "blobReadWriteToken": "",
    "updateServer": "https://seqdesk.org"
  }
}
