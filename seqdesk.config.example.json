{
  "_comment": "Copy this file to seqdesk.config.json and adjust values for your environment",

  "app": {
    "port": 3000
  },

  "site": {
    "name": "My Sequencing Facility",
    "dataBasePath": "/data/sequencing",
    "contactEmail": "sequencing@example.com"
  },

  "pipelines": {
    "enabled": true,
    "execution": {
      "mode": "local",
      "runDirectory": "/data/pipeline_runs",
      "conda": {
        "enabled": true,
        "path": "/opt/conda",
        "environment": "seqdesk-pipelines"
      },
      "slurm": {
        "enabled": false,
        "queue": "cpu",
        "cores": 4,
        "memory": "64GB",
        "timeLimit": 24,
        "options": ""
      }
    },
    "mag": {
      "enabled": true,
      "version": "3.4.0",
      "stubMode": false,
      "skipProkka": true,
      "skipConcoct": true
    }
  },

  "ena": {
    "testMode": true,
    "centerName": "My Center"
  },

  "sequencingFiles": {
    "extensions": [".fastq.gz", ".fq.gz", ".fastq", ".fq"],
    "scanDepth": 2,
    "allowSingleEnd": false,
    "ignorePatterns": ["**/tmp/**", "**/undetermined/**"],
    "simulationMode": "auto",
    "simulationTemplateDir": "_simulation_templates/mag"
  },

  "auth": {
    "allowRegistration": true,
    "requireEmailVerification": false,
    "sessionTimeout": 24
  },

  "runtime": {
    "databaseUrl": "postgresql://seqdesk:replace-with-local-db-password@127.0.0.1:5432/seqdesk?schema=public",
    "directUrl": "postgresql://seqdesk:replace-with-local-db-password@127.0.0.1:5432/seqdesk?schema=public",
    "nextAuthUrl": "http://localhost:8000",
    "nextAuthSecret": "",
    "anthropicApiKey": "",
    "adminSecret": "",
    "blobReadWriteToken": "",
    "updateServer": "https://seqdesk.com"
  }
}
